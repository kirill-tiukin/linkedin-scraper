# LinkedIn session cookie — get from browser DevTools → Application → Cookies → li_at
LI_AT=AQEDATxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LinkedIn JSESSIONID cookie (also from DevTools) — used for CSRF token
JSESSIONID="ajax:xxxxxxxxxxxxxxxxxxxxxxxx"

# Google Custom Search API (optional — for finding profiles by keyword)
# Free tier: 100 queries/day  https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
